          "name": "Avg Order Value",
          "source": { "kind": "table", "elementId": "tbl-plugs-tx" },
          "columns": [
            { "id": "kpi-aov-month", "formula": "DateTrunc(\"month\", [Date])" },
            { "id": "kpi-aov-value", "formula": "Sum([Quantity] * [Price]) / CountDistinct([Order Number])", "name": "Avg Order Value", "format": { "type": "number", "format": "currency", "currency": "USD" } },
            { "id": "kpi-aov-date", "formula": "[Plugs Transaction Details/Date]" },
            { "id": "kpi-aov-quantity", "formula": "[Plugs Transaction Details/Quantity]" },
            { "id": "kpi-aov-price", "formula": "[Plugs Transaction Details/Price]" },
            { "id": "kpi-aov-order", "formula": "[Plugs Transaction Details/Order Number]" }
          ],
          "value": { "id": "kpi-aov-value" }
        },
        {
          "id": "kpi-margin",
