        { "id": "container-kpis", "kind": "container" },
        {
          "id": "kpi-revenue",
          "kind": "kpi-chart",
          "name": "Total Revenue",
          "source": { "kind": "table", "elementId": "tbl-plugs-tx" },
          "columns": [
            { "id": "kpi-rev-month", "formula": "DateTrunc(\"month\", [Date])" },
            { "id": "kpi-rev-value", "formula": "[Metrics/Revenue]", "name": "Revenue" },
            { "id": "kpi-rev-date", "formula": "[Plugs Transaction Details/Date]" },
            { "id": "kpi-rev-quantity", "formula": "[Plugs Transaction Details/Quantity]" },
            { "id": "kpi-rev-price", "formula": "[Plugs Transaction Details/Price]" }
          ],
          "value": { "id": "kpi-rev-value" }
        },
        {
          "id": "kpi-active-customers",
          "kind": "kpi-chart",
          "name": "Active Customers",
          "source": { "kind": "table", "elementId": "tbl-plugs-tx" },
          "columns": [
            { "id": "kpi-cust-month", "formula": "DateTrunc(\"month\", [Date])" },
            { "id": "kpi-cust-value", "formula": "CountDistinct([Cust Key])", "name": "Active Customers" },
            { "id": "kpi-cust-date", "formula": "[Plugs Transaction Details/Date]" },
            { "id": "kpi-cust-key", "formula": "[Plugs Transaction Details/Cust Key]" }
          ],
          "value": { "id": "kpi-cust-value" }
        },
        {
          "id": "kpi-avg-order-value",
