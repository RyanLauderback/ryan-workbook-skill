            { "id": "kpi-margin-date", "formula": "[Plugs Transaction Details/Date]" },
            { "id": "kpi-margin-quantity", "formula": "[Plugs Transaction Details/Quantity]" },
            { "id": "kpi-margin-price", "formula": "[Plugs Transaction Details/Price]" },
            { "id": "kpi-margin-cost", "formula": "[Plugs Transaction Details/Cost]" }
          ],
          "value": { "id": "kpi-margin-value" }
