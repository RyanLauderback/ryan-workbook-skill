  "layout": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<Page type=\"grid\" gridTemplateColumns=\"repeat(24, 1fr)\" gridTemplateRows=\"auto\" id=\"page-overview\">\n  <GridContainer elementId=\"container-header\" type=\"grid\" gridColumn=\"1 / 25\" gridRow=\"1 / 4\" gridTemplateColumns=\"repeat(24, 1fr)\" gridTemplateRows=\"auto\">\n    <LayoutElement elementId=\"text-page-title\" gridColumn=\"1 / 10\" gridRow=\"1 / 4\"/>\n    <LayoutElement elementId=\"ctrl-date-range\" gridColumn=\"10 / 15\" gridRow=\"1 / 4\"/>\n    <LayoutElement elementId=\"ctrl-store-region\" gridColumn=\"15 / 20\" gridRow=\"1 / 4\"/>\n    <LayoutElement elementId=\"ctrl-product-family\" gridColumn=\"20 / 25\" gridRow=\"1 / 4\"/>\n  </GridContainer>\n  <GridContainer elementId=\"container-kpis\" type=\"grid\" gridColumn=\"1 / 25\" gridRow=\"4 / 14\" gridTemplateColumns=\"repeat(24, 1fr)\" gridTemplateRows=\"auto\">\n    <LayoutElement elementId=\"kpi-revenue\" gridColumn=\"1 / 7\" gridRow=\"1 / 10\"/>\n    <LayoutElement elementId=\"kpi-active-customers\" gridColumn=\"7 / 13\" gridRow=\"1 / 10\"/>\n    <LayoutElement elementId=\"kpi-avg-order-value\" gridColumn=\"13 / 19\" gridRow=\"1 / 10\"/>\n    <LayoutElement elementId=\"kpi-margin\" gridColumn=\"19 / 25\" gridRow=\"1 / 10\"/>\n  </GridContainer>\n  <GridContainer elementId=\"container-customers\" type=\"grid\" gridColumn=\"1 / 25\" gridRow=\"14 / 28\" gridTemplateColumns=\"repeat(24, 1fr)\" gridTemplateRows=\"auto\">\n    <LayoutElement elementId=\"text-customer-section\" gridColumn=\"1 / 25\" gridRow=\"1 / 2\"/>\n    <LayoutElement elementId=\"chart-top-customers\" gridColumn=\"1 / 13\" gridRow=\"2 / 14\"/>\n    <LayoutElement elementId=\"chart-revenue-by-region\" gridColumn=\"13 / 25\" gridRow=\"2 / 14\"/>\n  </GridContainer>\n  <GridContainer elementId=\"container-products\" type=\"grid\" gridColumn=\"1 / 25\" gridRow=\"28 / 42\" gridTemplateColumns=\"repeat(24, 1fr)\" gridTemplateRows=\"auto\">\n    <LayoutElement elementId=\"text-product-section\" gridColumn=\"1 / 25\" gridRow=\"1 / 2\"/>\n    <LayoutElement elementId=\"chart-top-products\" gridColumn=\"1 / 13\" gridRow=\"2 / 14\"/>\n    <LayoutElement elementId=\"chart-product-family\" gridColumn=\"13 / 25\" gridRow=\"2 / 14\"/>\n  </GridContainer>\n  <LayoutElement elementId=\"tbl-plugs-tx\" gridColumn=\"1 / 25\" gridRow=\"42 / 62\"/>\n</Page>\n"
